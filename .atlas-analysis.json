  "keyFeatures": [
    "IP geolocation using multiple APIs (ip-api.com and ipinfo.io)",
    "Phone number validation and carrier lookup with phonenumbers library",
    "Detailed geographic information including coordinates and timezone",
    "Automatic results export to timestamped text files",
    "Interactive CLI menu with comparison mode",
    "Support for multiple phone number formats (E.164, international, national)"
